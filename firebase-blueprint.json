{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email"
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "User's profile photo URL"
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of book IDs favorited by the user"
        },
        "readingHistory": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of book IDs read by the user"
        },
        "preferences": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of preferred genres"
        },
        "searchHistory": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of recent search queries"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User role"
        }
      },
      "required": ["uid", "displayName", "email", "favorites", "readingHistory", "preferences", "searchHistory"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User document containing favorites and profile info"
    }
  }
}
